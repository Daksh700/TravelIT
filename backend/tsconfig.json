{
  "compilerOptions": {
    "target": "es2020",             
    "module": "es2020",           
    "moduleResolution": "node",
    "lib": ["es2020"],              
    "outDir": "dist",               
    "rootDir": "src",               
    "strict": true,                 
    "esModuleInterop": true,        
    "skipLibCheck": true,           
    "forceConsistentCasingInFileNames": true,
    
    "resolveJsonModule": true,      
    "removeComments": true,        

    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],

  "ts-node": {
    "files": true
  }
}